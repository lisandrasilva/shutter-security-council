# ─── RPC / Signer ────────────────────────────────────────────────────────────
# Mainnet RPC URL (used by fork tests and broadcast scripts)
RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
# Also accepted by fork tests (takes priority over RPC_URL)
MAINNET_RPC_URL=

# Private key used by all scripts (deploy + proposal submission)
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# ─── Explorer Verification ───────────────────────────────────────────────────
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# ─── Step 1: Deploy SecurityCouncilAzorius ───────────────────────────────────
# Script: forge script script/DeploySecurityCouncilAzorius.s.sol
#
# Council multisig address (must be non-zero; constructor rejects address(0))
COUNCIL_ADDRESS=0xYOUR_COUNCIL_ADDRESS
# Azorius module on Shutter DAO
AZORIUS_ADDRESS=0xAA6BfA174d2f803b517026E93DBBEc1eBa26258e

# ─── Step 2: Submit Security Council Proposal ────────────────────────────────
# Script: forge script script/SubmitSecurityCouncilProposal.s.sol
#
# Address of the deployed SecurityCouncilAzorius guard (output of step 1)
GUARD_ADDRESS=0xYOUR_DEPLOYED_GUARD_ADDRESS

# ─── Step 3: Submit Governance Parameters Proposal ───────────────────────────
# Script: forge script script/SubmitGovernanceParametersProposal.s.sol
#
# No extra env vars needed — parameters are hardcoded in the library:
#   executionPeriod  = 50_400 blocks (~7 days)
#   proposerWeight   = 100_000e18 (100K SHU)

# ─── Step 4: Submit Spam Proposal (stress test only) ─────────────────────────
# Script: forge script script/SubmitSpamProposal.s.sol
#
# Contract address to target with trivial setNumber() calls
SPAM_TARGET=0xYOUR_TARGET_CONTRACT
# Number of spam proposals to submit (default: 100)
SPAM_COUNT=100

# ─── Step 5: Submit Hats Proposal Gating ─────────────────────────────────────
# Script: forge script script/SubmitHatsProposalGating.s.sol
#
# JSON array of addresses that will receive proposer hats
PROPOSER_HAT_WEARERS=["0xADDRESS_1","0xADDRESS_2"]

# ─── Reference Addresses (not consumed by scripts, for documentation) ────────
SAFE_ADDRESS=0x36bD3044ab68f600f6d3e081056F34f2a58432c4
SAFE_SINGLETON_ADDRESS=0xd9Db270c1B5E3Bd161E8c8503c55cEABeE709552
SAFE_VERSION=1.3.0
LINEAR_ERC20_VOTING_ADDRESS=0x4b29d8B250B8b442ECfCd3a4e3D91933d2db720F
SHUTTER_TOKEN_ADDRESS=0xe485E2f1bab389C08721B291f6b59780feC83Fd7
DEFAULT_PROPOSER_ADDRESS=0x9Cc9C7F874eD77df06dCd41D95a2C858cd2a2506
